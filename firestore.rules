rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isCoach(coachId) {
      return request.auth != null && request.auth.uid == coachId;
    }

    function athleteAccessDoc(uid) {
      return get(/databases/$(database)/documents/athleteAccess/$(uid)).data;
    }

    function isAthlete(coachId, athleteId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/athleteAccess/$(request.auth.uid))
        && athleteAccessDoc(request.auth.uid).coachId == coachId
        && athleteAccessDoc(request.auth.uid).athleteId == athleteId;
    }

    // ── Coaches ────────────────────────────────────────────────────────────────
    match /coaches/{coachId} {
      allow read, write: if isCoach(coachId);

      // ── Athletes subcollection ───────────────────────────────────────────────
      match /athletes/{athleteId} {
        allow read, write: if isCoach(coachId);
        // Athlete can read their own profile
        allow read: if isAthlete(coachId, athleteId);
        // Self-activation: athlete with valid auth can activate themselves
        allow update: if request.auth != null
          && resource.data.status == "pending"
          && request.resource.data.status == "active"
          && request.resource.data.athleteUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["athleteUid", "status"]);

        // ── Athlete programs ─────────────────────────────────────────────────
        match /programs/{programId} {
          allow read, write: if isCoach(coachId);
          allow read: if isAthlete(coachId, athleteId);
        }

        // ── Workout logs ─────────────────────────────────────────────────────
        match /logs/{logId} {
          allow read, write: if isCoach(coachId);
          allow read, write: if isAthlete(coachId, athleteId);
        }
      }
    }

    // ── AthleteAccess lookup ───────────────────────────────────────────────────
    match /athleteAccess/{uid} {
      // Athlete can read/write their own access doc (created on join)
      allow read, write: if request.auth != null && request.auth.uid == uid;
      // Coach can read their athletes' access docs (for admin lookups)
      allow read: if request.auth != null;
    }
  }
}
