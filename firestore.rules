rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isCoach(coachId) {
      return request.auth != null && request.auth.uid == coachId;
    }

    function athleteAccessDoc(uid) {
      return get(/databases/$(database)/documents/athleteAccess/$(uid)).data;
    }

    function isAthlete(coachId, athleteId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/athleteAccess/$(request.auth.uid))
        && athleteAccessDoc(request.auth.uid).coachId == coachId
        && athleteAccessDoc(request.auth.uid).athleteId == athleteId;
    }

    // ── Coaches ────────────────────────────────────────────────────────────────
    match /coaches/{coachId} {
      allow read, write: if isCoach(coachId);

      // Coach library: programs (templates)
      match /programs/{programId} {
        allow read, write: if isCoach(coachId);
      }

      // Coach library: invites (legacy, may not be used)
      match /invites/{inviteId} {
        allow read, write: if isCoach(coachId);
      }

      // Catch-all for any other coach-owned subcollections
      match /{anyCollection}/{anyDoc} {
        allow read, write: if isCoach(coachId);
      }

      // ── Groups ───────────────────────────────────────────────────────────────
      match /groups/{groupId} {
        function isGroupMember() {
          return request.auth != null
            && request.auth.uid in get(/databases/$(database)/documents/coaches/$(coachId)/groups/$(groupId)).data.memberUids;
        }

        allow read, write: if isCoach(coachId);
        // Members can read the group doc — also authorizes list queries
        // filtered with where("memberUids", "array-contains", uid)
        allow read: if request.auth != null && request.auth.uid in resource.data.memberUids;

        // Shared group programs — read-only for members
        match /programs/{programId} {
          allow read, write: if isCoach(coachId);
          allow read: if isGroupMember();
        }

        // Activity feed (fase 2 "gara"): members read, but entries are
        // written ONLY server-side by /api/group-feed (anti-cheating —
        // the entry is derived from the saved log, not client input)
        match /feed/{entryId} {
          allow read, write: if isCoach(coachId);
          allow read: if isGroupMember();
        }
      }

      // ── Athletes subcollection ───────────────────────────────────────────────
      match /athletes/{athleteId} {
        allow read, write: if isCoach(coachId);
        // Athlete can read their own profile
        allow read: if isAthlete(coachId, athleteId);
        // Self-activation: pending athlete with auth flips status to active
        allow update: if request.auth != null
          && resource.data.status == "pending"
          && request.resource.data.status == "active"
          && request.resource.data.athleteUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["athleteUid", "status"]);

        // Athlete programs
        match /programs/{programId} {
          allow read, write: if isCoach(coachId);
          allow read: if isAthlete(coachId, athleteId);
        }

        // Workout logs (shared between coach and athlete)
        match /logs/{logId} {
          allow read, write: if isCoach(coachId);
          allow read, write: if isAthlete(coachId, athleteId);
        }

        // Catch-all for any other athlete-owned subcollections
        match /{anyCollection}/{anyDoc} {
          allow read, write: if isCoach(coachId);
          allow read: if isAthlete(coachId, athleteId);
        }
      }
    }

    // ── Strava OAuth tokens (server-only) ──────────────────────────────────────
    // Access/refresh tokens never touch the client: the connect flow is handled
    // server-side (Admin SDK, which bypasses rules). Stored in their OWN doc —
    // NOT in athleteAccess — so the owning coach can't read an athlete's tokens.
    match /athleteStravaTokens/{uid} {
      allow read, write: if false;
    }

    // ── AthleteAccess lookup ───────────────────────────────────────────────────
    match /athleteAccess/{uid} {
      // Owner can read their own access doc
      allow read: if request.auth != null && request.auth.uid == uid;
      // The owning coach can read it (to map athletes back to UIDs)
      allow read: if request.auth != null && resource.data.coachId == request.auth.uid;
      // Owner can write it ONLY if the referenced athlete profile is really
      // theirs (athleteUid == their uid) — prevents self-linking to another
      // coach's athlete. Server-side flows (join-group, invite) bypass rules.
      allow write: if request.auth != null
        && request.auth.uid == uid
        && get(/databases/$(database)/documents/coaches/$(request.resource.data.coachId)/athletes/$(request.resource.data.athleteId)).data.athleteUid == request.auth.uid;
    }
  }
}
