ANTHROPIC_API_KEY=
GARMIN_CLIENT_ID=        # placeholder — Garmin OAuth2 client ID
GARMIN_CLIENT_SECRET=    # placeholder — Garmin OAuth2 client secret

# Strava integration (https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=        # numero intero da "My API Application" su Strava
STRAVA_CLIENT_SECRET=    # stringa da "My API Application" su Strava
STRAVA_STATE_SECRET=     # stringa random (es. openssl rand -hex 32) per firmare lo state OAuth

# Email invites (Resend — https://resend.com)
RESEND_API_KEY=           # re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=        # noreply@tuodominio.it  (deve essere un dominio verificato su Resend)
NEXT_PUBLIC_APP_URL=      # http://localhost:3000 in dev | https://tuodominio.it in prod
